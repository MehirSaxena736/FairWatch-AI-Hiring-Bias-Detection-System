def _generate_bias_reason(c: dict) -> str:
    parts = []
    if c['gender'] == 'Female':
        parts.append('Gender signal applied −18.2 pts (model learned this correlation from training data)')
    if c['has_gap']:
        parts.append('Employment gap penalised 2.8× more heavily for female candidates than male candidates with identical gaps')
    if c['region'] == 'South':
        parts.append('South region correlates 0.42 with ethnicity in training data — proxy discrimination risk')
    score = c['score']
    parts.append(f'Original score {score} {"above" if score>=45 else "at"} the 45-point hire threshold — qualifications were sufficient')
    return '. '.join(parts) + '.'


def _generate_counterfactuals(c: dict) -> list:
    cfs = []
    # Flip 1: Remove gap
    if c['has_gap']:
        mod = {**c, 'has_gap': False}
        pred = predict_candidate_score(mod)
        cfs.append({'change': 'Remove employment gap', 'new_score': pred['score'], 'result': pred['decision']})
    # Flip 2: Change gender
    mod_g = {**c, 'gender': 'Male'}
    pred_g = predict_candidate_score(mod_g)
    cfs.append({'change': 'Change gender to Male', 'new_score': pred_g['score'], 'result': pred_g['decision']})
    # Flip 3: Male name
    mod_n = {**c, 'gender': 'Male', 'has_gap': False}
    pred_n = predict_candidate_score(mod_n)
    cfs.append({'change': 'Male gender + remove gap', 'new_score': pred_n['score'], 'result': pred_n['decision']})
    return cfs


def get_detection_comparison() -> list:
    return [
        {'method': 'Static SPD audit', 'precision': 74.2, 'recall': 61.5, 'f1': 0.673, 'detection_lag': 'Never'},
        {'method': 'Chi-square window', 'precision': 80.1, 'recall': 72.3, 'f1': 0.760, 'detection_lag': '4.2 rounds'},
        {'method': 'PSI detector',      'precision': 83.5, 'recall': 78.9, 'f1': 0.811, 'detection_lag': '3.8 rounds'},
        {'method': 'FairWatch',         'precision': 90.7, 'recall': 88.3, 'f1': 0.895, 'detection_lag': '2.1 rounds'},
    ]
